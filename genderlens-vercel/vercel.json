{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "detect/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "learn/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/detect",
      "dest": "/detect/index.html"
    },
    {
      "src": "/learn",
      "dest": "/learn/index.html"
    }
  ]
}